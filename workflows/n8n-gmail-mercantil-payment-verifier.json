{
  "id": "cbd7a163-e53b-4d07-b3dd-b1819e2d1c7d",
  "name": "PoleraFlow Gmail Mercantil Payment Verifier",
  "active": false,
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
