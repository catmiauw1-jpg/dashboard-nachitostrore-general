            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-API-Key",
              "value": "={{ $env.YCLOUD_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.ycloudRequest }}",
        "options": {}
      },
      "id": "ef855e5a-af03-4401-8695-1b8fd0ee5d98",
