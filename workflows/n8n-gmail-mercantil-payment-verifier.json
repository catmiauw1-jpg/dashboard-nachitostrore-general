      "id": "85242d95-b770-41f0-8f6a-7d7fb079edc1",
      "name": "Gmail Mercantil Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.3,
      "position": [
        -940,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const email = $json;\n\nfunction decodeBase64Url(value) {\n  if (!value) return '';\n  const normalized = String(value).replace(/-/g, '+').replace(/_/g, '/');\n  const padded = normalized.padEnd(normalized.length + ((4 - normalized.length % 4) % 4), '=');\n  return Buffer.from(padded, 'base64').toString('utf8');\n}\n\nfunction collectParts(part, output = []) {\n  if (!part) return output;\n  if (part.mimeType && part.body?.data) {\n    output.push({ mimeType: part.mimeType, text: decodeBase64Url(part.body.data) });\n  }\n  if (Array.isArray(part.parts)) {\n    for (const child of part.parts) collectParts(child, output);\n  }\n  return output;\n}\n\nconst headers = Object.fromEntries((email.payload?.headers || []).map((header) => [String(header.name || '').toLowerCase(), header.value || '']));\nconst parts = collectParts(email.payload);\nconst plain = parts.find((part) => /text\\/plain/i.test(part.mimeType))?.text || '';\nconst html = parts.find((part) => /text\\/html/i.test(part.mimeType))?.text || '';\nconst body = plain || html.replace(/<[^>]*>/g, ' ') || email.textPlain || email.textHtml || email.snippet || '';\nconst from = email.from || headers.from || '';\n\nreturn {\n  json: {\n    id: email.id || email.messageId,\n    messageId: email.id || email.messageId,\n    threadId: email.threadId,\n    from,\n    subject: email.subject || headers.subject || '',\n    snippet: email.snippet || '',\n    body,\n    email_ts: email.internalDate ? new Date(Number(email.internalDate)).toISOString() : new Date().toISOString()\n  }\n};"
      },
      "id": "4cc250c6-5e56-454d-bbe4-8827875c7a4d",
      "name": "Normalize Mercantil Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -680,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.POLERAFLOW_MERCANTIL_PAYMENT_URL || 'https://admin-dhasboard.vercel.app/api/webhooks/gmail/mercantil-payment' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-poleraflow-webhook-secret",
              "value": "={{ $env.POLERAFLOW_WEBHOOK_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      },
      "id": "7dc3b572-7c3e-4aef-a988-990be0ebc2f0",
      "name": "Verify Payment in PoleraFlow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -420,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.matched === true && !!$json.phone && !!$json.replyText }}",
              "value2": true
            }
          ]
        }
      },
      "id": "f70892c4-8401-4bf4-b5bf-6e8499fb19f1",
      "name": "Payment Matched?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -160,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const result = $json;\nconst rawPhone = String(result.phone || '').replace(/\\D/g, '');\nconst toPhone = rawPhone ? (rawPhone.startsWith('+') ? rawPhone : `+${rawPhone}`) : '';\nconst fromPhone = String($env.YCLOUD_WHATSAPP_FROM || '+59178096231').trim();\n\nif (!toPhone || !fromPhone || !result.replyText) {\n  return { json: { shouldSend: false, reason: 'missing phone or text', result } };\n}\n\nreturn {\n  json: {\n    shouldSend: true,\n    result,\n    ycloudRequest: {\n      from: fromPhone,\n      to: toPhone,\n      type: 'text',\n      text: {\n        body: result.replyText\n      }\n    }\n  }\n};"
      },
      "id": "cf7bc68a-ab89-4456-b5d4-3a291f040981",
      "name": "Build YCloud Payment Confirmation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        100,
        -120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.ycloud.com/v2/whatsapp/messages/sendDirectly",
        "sendHeaders": true,
        "headerParameters": {
