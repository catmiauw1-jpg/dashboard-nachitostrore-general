NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server only. Never expose this in the browser or in Nachito Store.
# Required for dashboard writes, product deletion and uploads in production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server only. Shared secret used by n8n when it calls /api/webhooks/n8n/whatsapp.
N8N_WEBHOOK_SECRET=change-this-long-random-secret

# Public store URL used by the WhatsApp bot when a customer writes before ordering.
NACHITO_STORE_URL=https://nachitostore.vercel.app
POLERAFLOW_PUBLIC_URL=https://admin-dhasboard.vercel.app
MANUAL_PAYMENT_QR_URL=https://admin-dhasboard.vercel.app/payment/mercantil-qr.jpeg

# Server only. Enables AI reading for WhatsApp payment proof images/PDFs.
# If empty, proofs are still stored and Gmail verification continues with rules.
PROOF_AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PROOF_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your-openai-api-key
OPENAI_PROOF_MODEL=gpt-4o-mini

# Optional open-source / OpenAI-compatible verifier for payment matching.
# Use PAYMENT_AI_PROVIDER=ollama on a VPS with Ollama, or openai-compatible
# for providers that expose /chat/completions.
PAYMENT_AI_PROVIDER=disabled
PAYMENT_AI_BASE_URL=http://127.0.0.1:11434
PAYMENT_AI_MODEL=llava:latest
PAYMENT_AI_API_KEY=
PAYMENT_AI_MIN_CONFIDENCE=0.78

# Optional open-source proof reader. Set PROOF_AI_PROVIDER=ollama or
# openai-compatible and reuse the same BASE_URL/MODEL values above.
PROOF_AI_BASE_URL=
PROOF_AI_MODEL=
PROOF_AI_API_KEY=

# Future payment gateway switch. Keep disabled until PagosBolivia/Banco Economico is ready.
PAYMENT_PROVIDER=manual_pending_gateway
PAYMENT_GATEWAY_ENABLED=false

# n8n local helper variables.
POLERAFLOW_BOT_URL=https://admin-dhasboard.vercel.app/api/webhooks/n8n/waflow-bot
POLERAFLOW_PROOF_AI_URL=https://admin-dhasboard.vercel.app/api/webhooks/n8n/payment-proof-ai
POLERAFLOW_WEBHOOK_SECRET=change-this-long-random-secret
WAFLOW_API_KEY=your-waflow-api-key
YCLOUD_API_KEY=your-ycloud-api-key
YCLOUD_WHATSAPP_FROM=+59178096231
