NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server only. Never expose this in the browser or in Nachito Store.
# Required for dashboard writes, product deletion and uploads in production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server only. Shared secret used by n8n when it calls /api/webhooks/n8n/whatsapp.
N8N_WEBHOOK_SECRET=change-this-long-random-secret
